rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function signedIn() { 
        return request.auth != null; 
    }
    
    // Helper function to check if the user is a participant of a given chat document
    function isUserParticipant(chatId) {
        return exists(/databases/$(database)/documents/chats/$(chatId))
               && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }
    
    // 1. USER COLLECTION
    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && request.auth.uid == userId; 
    }
    
    // 2. FRIEND REQUESTS
    match /friendRequests/{requestId} {
      allow create: if signedIn();
      allow delete: if signedIn() && resource.data.senderId == request.auth.uid; 
      allow update: if signedIn() && resource.data.receiverId == request.auth.uid;
      allow read: if signedIn() && (
                       resource.data.senderId == request.auth.uid ||
                       resource.data.receiverId == request.auth.uid
                    );
    }
    
    // 3. FRIENDSHIPS
    match /friendships/{friendshipId} {
      allow create: if signedIn();
      allow read, update, delete: if signedIn() && (
          resource.data.user1Id == request.auth.uid || 
          resource.data.user2Id == request.auth.uid
      );
    }
    
    // 4. CHATS - FIXED FOR CREATE OR GET
    match /chats/{chatId} {
      // Allow get operation for checking existence (needed for createOrGetChat)
      // Allow list/read only if user is a participant
      allow get: if signedIn();
      allow list, read: if signedIn() && request.auth.uid in resource.data.participants;
      
      // Create: must include current user in participants
      allow create: if signedIn()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;
      
      // Update: must be a participant
      allow update: if signedIn()
        && request.auth.uid in resource.data.participants;
      
      // Delete: must be a participant
      allow delete: if signedIn()
        && request.auth.uid in resource.data.participants;
    }
    
    // 5. MESSAGES - FIXED
    match /messages/{messageId} {
      // Create: user must be sender AND a participant of the chat
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.senderId
        && request.resource.data.chatId is string 
        && isUserParticipant(request.resource.data.chatId);
      
      // Read: Must be authenticated and be a chat participant
      allow read: if signedIn()
        && resource.data.chatId is string 
        && isUserParticipant(resource.data.chatId);
      
      // Update: Allow BOTH sender (edit) AND receiver (markAsRead)
      allow update: if signedIn()
        && resource.data.chatId is string 
        && isUserParticipant(resource.data.chatId)
        && (
          request.auth.uid == resource.data.senderId
          || request.auth.uid == resource.data.receiverId
        );
      
      // Delete: Only sender can delete their own message
      allow delete: if signedIn()
        && request.auth.uid == resource.data.senderId;
    }
    
    // 6. NOTIFICATIONS
    match /notifications/{id} {
      allow create: if signedIn();
      allow read, update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
